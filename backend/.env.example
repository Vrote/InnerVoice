# Groq API — single key for both LLM and Embeddings
GROQ_API_KEY=your_groq_api_key_here

# LLM Models
GROQ_ORCHESTRATOR_MODEL=llama3-70b-8192
GROQ_TOOL_MODEL=llama3-8b-8192
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1.5

# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./innervoice.db

# Security
SECRET_KEY=9a263158c5c7db8bf1db884b23267d3e69f4ea5fb54d68ab73a388b3be89520c
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# App Settings
APP_ENV=development
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Agent behavior
MAX_REASONING_ITERATIONS=8
MAX_FOLLOWUP_TURNS=2
AGENT_TIMEOUT_SECONDS=90
